{
  "name": "tencent-docs-markdown",
  "version": "1.1.3",
  "description": "Tencent Docs Markdown Skill - Create, upload, download, and delete Markdown documents via natural language",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "login": "node src/index.js login",
    "login:force": "node src/index.js login --force",
    "publish": "./publish.sh",
    "publish:patch": "./publish.sh patch",
    "publish:minor": "./publish.sh minor",
    "publish:major": "./publish.sh major",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx --fix",
    "test": "jest --coverage",
    "type-check": "tsc --noEmit",
    "lint:check": "eslint . --ext .ts,.tsx,.js,.jsx",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "axios": "^1.7.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "ora": "^5.4.1",
    "puppeteer": "^22.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "keywords": [
    "tencent",
    "docs",
    "markdown"
  ],
  "author": "wscats (https://github.com/wscats)",
  "repository": {
    "type": "git",
    "url": "https://github.com/wscats/tencent-docs-markdown.git"
  },
  "bugs": {
    "url": "https://github.com/wscats/tencent-docs-markdown/issues"
  },
  "homepage": "https://github.com/wscats/tencent-docs-markdown#readme"
}
